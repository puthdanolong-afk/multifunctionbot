# TELEGRAM_BOT_TOKEN: Required to run the Telegram Bot.
# Get this from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# COBALT_API_KEY: Optional. Required for downloading videos from Instagram/Facebook/Threads.
# The public Cobalt API requires authentication.
COBALT_API_KEY="YOUR_COBALT_API_KEY"
COBALT_API_URL="https://api.cobalt.tools/"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_TELEGRAM_ID: Optional. Your Telegram User ID to receive notifications about new users and use admin commands.
ADMIN_TELEGRAM_ID="YOUR_TELEGRAM_ID"

# YOUTUBE_PO_TOKEN: Optional. Used to bypass YouTube bot detection and rate limiting.
YOUTUBE_PO_TOKEN="YOUR_YOUTUBE_PO_TOKEN"

# YOUTUBE_VISITOR_DATA: Optional. Used alongside YOUTUBE_PO_TOKEN to bypass YouTube bot detection.
YOUTUBE_VISITOR_DATA="YOUR_YOUTUBE_VISITOR_DATA"
